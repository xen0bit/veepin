# Keep the veepin build context small and deterministic. The root Dockerfile
# needs the Go module source (cmd/, internal/, client/, dataplane/, ikev2/) plus
# go.mod and go.sum, which it copies first so the dependency layer caches
# independently of the source.
.git
dist/
bin/
nm/bin/
tests/interop/**/bin
*.deb
*.rpm
*.apk
