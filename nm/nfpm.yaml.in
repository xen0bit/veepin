# nfpm config for the veepin NetworkManager plugin package.
#
# Built via `make packages` (which exports VERSION, PKG_ARCH, MULTIARCH). This
# is a SEPARATE package from the CGO-free core: it carries a libnm/libgtk-3
# runtime dependency because of the GUI editor .so, so it must not be bundled
# with the static core binaries.
name: veepin-nm
arch: @PKG_ARCH@
platform: linux
version: @VERSION@
section: net
priority: optional
maintainer: Remy <21974988+xen0bit@users.noreply.github.com>
description: |
  NetworkManager VPN plugin for the veepin IKEv2 VPN.
  Adds an "IKEv2 (veepin)" VPN type to NetworkManager: a D-Bus service that
  drives the veepin VPN client plus a GTK editor for the connection form.
  No dependency on strongSwan.
vendor: veepin
homepage: https://github.com/xen0bit/veepin
license: MIT

depends:
  - network-manager
  - libgtk-3-0

overrides:
  rpm:
    depends:
      - NetworkManager
      - gtk3
  apk:
    depends:
      - networkmanager
      - gtk+3.0

scripts:
  postinstall: scripts/postinstall.sh
  postremove: scripts/postremove.sh

contents:
  - src: bin/nm-veepin-service
    dst: /usr/lib/NetworkManager/nm-veepin-service
    file_info:
      mode: 0755
  - src: bin/nm-veepin-auth-dialog
    dst: /usr/lib/NetworkManager/nm-veepin-auth-dialog
    file_info:
      mode: 0755
  - src: bin/libnm-vpn-plugin-veepin.so
    dst: /usr/lib/@MULTIARCH@/NetworkManager/libnm-vpn-plugin-veepin.so
    file_info:
      mode: 0644
  - src: data/nm-veepin-service.name
    dst: /usr/lib/NetworkManager/VPN/nm-veepin-service.name
    file_info:
      mode: 0644
  - src: data/nm-veepin-service.conf
    dst: /usr/share/dbus-1/system.d/nm-veepin-service.conf
    file_info:
      mode: 0644
