# nfpm config for the ikennkt NetworkManager plugin package.
#
# Built via `make packages` (which exports VERSION, PKG_ARCH, MULTIARCH). This
# is a SEPARATE package from the CGO-free core: it carries a libnm/libgtk-3
# runtime dependency because of the GUI editor .so, so it must not be bundled
# with the static core binaries.
name: ikennkt-nm
arch: @PKG_ARCH@
platform: linux
version: @VERSION@
section: net
priority: optional
maintainer: Remy <remaclematt@gmail.com>
description: |
  NetworkManager VPN plugin for the ikennkt IKEv2 VPN.
  Adds an "IKEv2 (ikennkt)" VPN type to NetworkManager: a D-Bus service that
  drives the ikennkt VPN client plus a GTK editor for the connection form.
  No dependency on strongSwan.
vendor: ikennkt
homepage: https://github.com/xen0bit/ikennkt
license: MIT

depends:
  - network-manager
  - libgtk-3-0

overrides:
  rpm:
    depends:
      - NetworkManager
      - gtk3
  apk:
    depends:
      - networkmanager
      - gtk+3.0

scripts:
  postinstall: scripts/postinstall.sh
  postremove: scripts/postremove.sh

contents:
  - src: bin/nm-ikennkt-service
    dst: /usr/lib/NetworkManager/nm-ikennkt-service
    file_info:
      mode: 0755
  - src: bin/libnm-vpn-plugin-ikennkt.so
    dst: /usr/lib/@MULTIARCH@/NetworkManager/libnm-vpn-plugin-ikennkt.so
    file_info:
      mode: 0644
  - src: data/nm-ikennkt-service.name
    dst: /usr/lib/NetworkManager/VPN/nm-ikennkt-service.name
    file_info:
      mode: 0644
  - src: data/nm-ikennkt-service.conf
    dst: /usr/share/dbus-1/system.d/nm-ikennkt-service.conf
    file_info:
      mode: 0644
